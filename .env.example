# ─── OSIRIS — Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in values.
# Legend: [SET] = value exists in .env  [BLANK] = key present, no value
#         [MISSING] = not in .env at all  [OPTIONAL] = graceful fallback if unset
# ──────────────────────────────────────────────────────────────────────────────

# ── Maritime tracking ──────────────────────────────────────────────────────────
AIS_API_KEY=                          # [SET] aisstream.io — live vessel positions

# ── OSINT enrichment ───────────────────────────────────────────────────────────
SHODAN_API_KEY=                       # [SET] free oss tier — host lookup works,
                                      #       host search (exposed cams, discovery) blocked
                                      #       until paid membership (~$49 one-time)

CENSYS_API_ID=                        # [SET] Censys PAT — passive host enrichment
                                      #   PAT (censys_* prefix): secret NOT needed — Bearer auth only
                                      #   Legacy key/secret pair: set both ID + SECRET (Basic auth)
                                      #   Generate at https://app.censys.io/account/api
CENSYS_API_SECRET=                    # [BLANK] only needed for legacy key+secret auth (not PAT)

# ── Telegram push alerts ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                   # [BLANK] hourly digest + threshold alerts dead until set
TELEGRAM_CHAT_ID=                     # [BLANK] create bot via @BotFather; get chat ID via @userinfobot

# ── Camera expansion ───────────────────────────────────────────────────────────
WINDY_WEBCAM_KEY=                     # [MISSING/OPTIONAL] Windy webcam bbox for Ukraine
                                      #   free tier 500 req/day: https://api.windy.com/

# ── Internal / infrastructure ──────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=                # [MISSING/OPTIONAL] webhook signature verification — skipped if unset
SDK_INGEST_KEY=                       # [MISSING/OPTIONAL] auth for /api/sdk/ingest — falls back to 'polybolos-dev-key'
UMAMI_WEBSITE_ID=                     # [MISSING/OPTIONAL] analytics — hardcoded fallback ID in middleware
SHADOW_FLEET_SOURCE_URL=              # [MISSING/OPTIONAL] override OFAC SDN source URL — defaults to treasury.gov
OSIRIS_SELF_ORIGIN=http://localhost:3001   # [OPTIONAL] base URL for /api/oblast-pressure internal self-fetch

# ── Thermal AOI fire sources ──────────────────────────────────────────────────
FIRMS_MAP_KEY=                        # [MISSING/HIGH] NASA FIRMS map key — unlocks area API (smaller bbox queries,
                                      #   2-day window, NOAA-20/21 NRT). Free: https://firms.modaps.eosdis.nasa.gov/
EUMETSAT_CONSUMER_KEY=                # [MISSING/OPTIONAL] EUMETSAT API consumer key — enables LSA-SAF FRP-PIXEL
                                      #   from Meteosat SEVIRI (15-min geostationary, EU+Russia coverage).
EUMETSAT_CONSUMER_SECRET=             # [MISSING/OPTIONAL] paired secret for above.
                                      #   Free registration: https://eoportal.eumetsat.int → API → Keys

# ── Conflict event aggregator ─────────────────────────────────────────────────
UCDP_ACCESS_TOKEN=                    # [MISSING/OPTIONAL] UCDP GED API token — enables UCDP gedevents source
                                      #   Register at https://ucdpapi.pcr.uu.se/
RELIEFWEB_APPNAME=                    # [MISSING/OPTIONAL] ReliefWeb v2 appname — currently 403 (pending approval)
                                      #   Request at https://reliefweb.int/help/api

# ── UI flags ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TG_ENABLED=               # [MISSING/OPTIONAL] cosmetic badge only — set to '1' when TG is configured
